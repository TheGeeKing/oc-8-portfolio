    "react-icons": "^5.4.0",
    "zod": "^3.23.3"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.14.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.7",
    "postcss": "^8.4.39",
    "prettier": "^3.3.2",
